# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=hema
POSTGRES_PASSWORD=change-me
POSTGRES_DB=hema
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# DSN, собранный из значений выше (для сервера/миграций)
DATABASE_URL=postgres://hema:change-me@localhost:5432/hema?sslmode=disable

# ── Go server ─────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# JWT: замените на длинные случайные строки (например `openssl rand -base64 48`)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# ── Bootstrap admin ────────────────────────────────────────────
# Креды для создания первого админа при старте сервера. Заполняйте только
# при первом развёртывании: если админов в БД ещё нет, сервер создаст одного
# с этими кредами. После первого входа ROTIRUЙТЕ пароль админа и уберите
# эти переменные из окружения (бутстрап идемпотентно пропустится).
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_DISPLAY_NAME=Admin

# ── Web / BFF ─────────────────────────────────────────────────
# Адрес Go-сервера, куда BFF ходит по gRPC/Connect
SERVER_GRPC_URL=http://localhost:8080
# Порт Next.js
WEB_PORT=3000
